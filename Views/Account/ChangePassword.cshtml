@model gestor_financiero.ViewModels.ChangePasswordViewModel
@{ ViewBag.Title = "Cambiar contraseña"; }

<style>
    .cp-with-eye { position: relative; }
    .cp-with-eye input { padding-right: 2.5rem !important; }
    .cp-eye-btn { position: absolute; right: 0.5rem; top: 50%; transform: translateY(-50%);
        background: transparent; border: 0; cursor: pointer; color: #64748b; padding: 0.375rem;
        display: flex; align-items: center; justify-content: center; }
    .cp-eye-btn:hover { color: #4f46e5; }
</style>

<div class="max-w-xl mx-auto bg-white rounded-xl shadow-sm border border-slate-100 p-6">
    <div class="mb-4 pb-4 border-b border-slate-100">
        <h2 class="text-lg font-semibold text-slate-800">Cambiar contraseña</h2>
        <p class="text-sm text-slate-500">Ingresá tu contraseña actual y elegí una nueva.</p>
    </div>

    @using (Html.BeginForm("ChangePassword", "Account", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-rose-600 text-sm block mb-2 bg-rose-50 border border-rose-100 rounded-lg px-3 py-2" })

        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Contraseña actual</label>
                <div class="cp-with-eye">
                    @Html.PasswordFor(m => m.PasswordActual, new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", id = "cpActual", placeholder = "Tu contraseña actual" })
                    <button type="button" class="cp-eye-btn" data-target="cpActual" aria-label="Mostrar/ocultar"><i class="icon-eye"></i></button>
                </div>
                @Html.ValidationMessageFor(m => m.PasswordActual, "", new { @class = "text-rose-600 text-xs mt-1 block" })
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Nueva contraseña</label>
                <div class="cp-with-eye">
                    @Html.PasswordFor(m => m.PasswordNueva, new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", id = "cpNueva", placeholder = "Mínimo 8 caracteres" })
                    <button type="button" class="cp-eye-btn" data-target="cpNueva" aria-label="Mostrar/ocultar"><i class="icon-eye"></i></button>
                </div>
                @Html.ValidationMessageFor(m => m.PasswordNueva, "", new { @class = "text-rose-600 text-xs mt-1 block" })
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Confirmar nueva contraseña</label>
                <div class="cp-with-eye">
                    @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", id = "cpConfirm", placeholder = "Repetir contraseña" })
                    <button type="button" class="cp-eye-btn" data-target="cpConfirm" aria-label="Mostrar/ocultar"><i class="icon-eye"></i></button>
                </div>
                @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-rose-600 text-xs mt-1 block" })
            </div>
        </div>

        <div class="flex gap-2 pt-6 mt-6 border-t border-slate-100">
            <button type="submit" class="px-5 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg font-medium">Cambiar contraseña</button>
            <a href="@Url.Action("Index", "Usuario")" class="px-5 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg font-medium">Cancelar</a>
        </div>
    }
</div>

<script>
    document.querySelectorAll('.cp-eye-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var input = document.getElementById(btn.dataset.target);
            if (!input) return;
            var ico = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                if (ico) { ico.classList.remove('icon-eye'); ico.classList.add('icon-eye-off'); }
            } else {
                input.type = 'password';
                if (ico) { ico.classList.remove('icon-eye-off'); ico.classList.add('icon-eye'); }
            }
        });
    });
</script>
