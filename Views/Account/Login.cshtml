@model gestor_financiero.ViewModels.LoginViewModel
@{
    ViewBag.Title = "Iniciar Sesión";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-600 via-indigo-700 to-slate-900 p-4">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <div class="inline-flex w-16 h-16 bg-white rounded-2xl items-center justify-center font-bold text-3xl text-indigo-600 shadow-xl mb-4">$</div>
            <h1 class="text-3xl font-bold text-white">Gestor Financiero</h1>
            <p class="text-indigo-200 mt-1">Toma el control de tu dinero</p>
        </div>

        <div class="bg-white rounded-2xl shadow-2xl p-8">
            <h2 class="text-2xl font-bold text-slate-800 mb-1">Bienvenido</h2>
            <p class="text-slate-500 text-sm mb-6">Ingresa tus credenciales para continuar</p>

            @using (Html.BeginForm("Login", "Account", new { returnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "space-y-4" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-rose-600 text-sm" })

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Correo electrónico</label>
                    @Html.TextBoxFor(m => m.Email, new { @class = "w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none", type = "email", placeholder = "tu@email.com" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-rose-600 text-xs mt-1" })
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Contraseña</label>
                    @Html.PasswordFor(m => m.Password, new { @class = "w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none", placeholder = "••••••••" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-rose-600 text-xs mt-1" })
                </div>

                <div class="flex items-center justify-between text-sm">
                    <label class="flex items-center gap-2 text-slate-600">
                        @Html.CheckBoxFor(m => m.RememberMe, new { @class = "w-4 h-4 rounded text-indigo-600" })
                        Recordarme
                    </label>
                </div>

                <button type="submit" class="w-full py-3 bg-gradient-to-r from-indigo-600 to-indigo-700 hover:from-indigo-700 hover:to-indigo-800 text-white font-semibold rounded-lg shadow-lg transition-all">
                    Iniciar sesión
                </button>
            }

            <div class="mt-6 text-center text-sm text-slate-600">
                ¿No tienes cuenta?
                <a href="@Url.Action("Register")" class="text-indigo-600 hover:text-indigo-700 font-medium">Regístrate</a>
            </div>
        </div>
    </div>
</div>
