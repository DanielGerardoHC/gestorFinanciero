@model gestor_financiero.ViewModels.RegisterViewModel
@{
    ViewBag.Title = "Registro";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-600 via-indigo-700 to-slate-900 p-4">
    <div class="w-full max-w-md">
        <div class="text-center mb-6">
            <div class="inline-flex w-16 h-16 bg-white rounded-2xl items-center justify-center font-bold text-3xl text-indigo-600 shadow-xl mb-4">$</div>
            <h1 class="text-3xl font-bold text-white">Crear cuenta</h1>
            <p class="text-indigo-200 mt-1">Empieza a gestionar tus finanzas hoy</p>
        </div>

        <div class="bg-white rounded-2xl shadow-2xl p-8">
            @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { @class = "space-y-4" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-rose-600 text-sm" })

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Nombre completo</label>
                    @Html.TextBoxFor(m => m.Nombre, new { @class = "w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" })
                    @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-rose-600 text-xs mt-1" })
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Correo electrónico</label>
                    @Html.TextBoxFor(m => m.Email, new { @class = "w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none", type = "email" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-rose-600 text-xs mt-1" })
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Contraseña</label>
                    @Html.PasswordFor(m => m.Password, new { @class = "w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-rose-600 text-xs mt-1" })
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Confirmar contraseña</label>
                    @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" })
                    @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-rose-600 text-xs mt-1" })
                </div>

                <button type="submit" class="w-full py-3 bg-gradient-to-r from-indigo-600 to-indigo-700 hover:from-indigo-700 hover:to-indigo-800 text-white font-semibold rounded-lg shadow-lg transition-all">
                    Crear cuenta
                </button>
            }

            <div class="mt-6 text-center text-sm text-slate-600">
                ¿Ya tienes cuenta?
                <a href="@Url.Action("Login")" class="text-indigo-600 hover:text-indigo-700 font-medium">Inicia sesión</a>
            </div>
        </div>
    </div>
</div>
