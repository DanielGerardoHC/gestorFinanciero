@model gestor_financiero.ViewModels.RegisterViewModel
@{
    ViewBag.Title = "Crear cuenta";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Estilos CSS estandar (no Tailwind) para que el split panel funcione SIN
   importar el estado de "npm run build". Asi los placeholders, gradientes y
   responsive layout se ven correctos siempre. *@
<style>
    .auth-wrap {
        min-height: 100vh;
        display: flex;
        align-items: stretch;
        background: #f8fafc;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }
    .auth-brand {
        display: none;
        width: 50%;
        position: relative;
        overflow: hidden;
        color: white;
        background: linear-gradient(135deg, #4f46e5 0%, #4338ca 50%, #0f172a 100%);
    }
    @@media (min-width: 1024px) {
        .auth-brand { display: flex; }
    }
    .auth-brand::before, .auth-brand::after {
        content: ''; position: absolute; width: 24rem; height: 24rem;
        border-radius: 50%; filter: blur(80px);
    }
    .auth-brand::before { top: -6rem; left: -6rem; background: rgba(129,140,248,0.35); }
    .auth-brand::after  { bottom: -6rem; right: -6rem; background: rgba(139,92,246,0.30); }
    .auth-brand-inner {
        position: relative; z-index: 1;
        display: flex; flex-direction: column; justify-content: space-between;
        padding: 3rem; width: 100%;
    }
    .brand-logo {
        display: flex; align-items: center; gap: 0.75rem;
    }
    .brand-logo .dollar {
        width: 3rem; height: 3rem; background: white; color: #4f46e5;
        border-radius: 0.75rem; display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 1.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    .brand-logo .title { font-weight: 700; font-size: 1.125rem; line-height: 1.2; }
    .brand-logo .subtitle { font-size: 0.75rem; color: #c7d2fe; }
    .brand-headline {
        font-size: 2.25rem; font-weight: 700; line-height: 1.15; margin: 0 0 0.75rem;
    }
    .brand-sub {
        color: #c7d2fe; font-size: 1.0625rem; max-width: 28rem; margin: 0 0 2rem;
    }
    .brand-list { list-style: none; padding: 0; margin: 0; }
    .brand-list li { display: flex; gap: 0.75rem; margin-bottom: 1rem; }
    .brand-list .ico {
        width: 2.25rem; height: 2.25rem; flex-shrink: 0;
        background: rgba(255,255,255,0.10); border-radius: 0.5rem;
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem;
    }
    .brand-list .h { font-weight: 600; }
    .brand-list .p { font-size: 0.875rem; color: #c7d2fe; }
    .brand-foot { font-size: 0.75rem; color: #a5b4fc; }

    .auth-form {
        flex: 1; display: flex; align-items: center; justify-content: center;
        padding: 1rem;
    }
    @@media (min-width: 640px) { .auth-form { padding: 2rem; } }
    .auth-card {
        width: 100%; max-width: 26rem;
    }
    .auth-mobile-header {
        text-align: center; margin-bottom: 1.5rem;
    }
    @@media (min-width: 1024px) { .auth-mobile-header { display: none; } }
    .auth-mobile-header .logo {
        display: inline-flex; width: 3.5rem; height: 3.5rem;
        background: linear-gradient(135deg, #6366f1, #4338ca); color: white;
        border-radius: 1rem; align-items: center; justify-content: center;
        font-weight: 700; font-size: 1.5rem; margin-bottom: 0.75rem;
        box-shadow: 0 10px 25px rgba(79,70,229,0.30);
    }
    .auth-mobile-header h1 { font-size: 1.5rem; font-weight: 700; color: #1e293b; margin: 0; }

    .auth-box {
        background: white; border: 1px solid #f1f5f9; border-radius: 1rem;
        padding: 2rem 1.75rem;
        box-shadow: 0 20px 50px rgba(0,0,0,0.08);
    }
    .auth-box h2 { font-size: 1.75rem; font-weight: 700; color: #1e293b; margin: 0; }
    .auth-box .sub { color: #64748b; font-size: 0.875rem; margin: 0.25rem 0 1.5rem; }

    .field { margin-bottom: 1rem; }
    .field label {
        display: block; font-size: 0.875rem; font-weight: 500;
        color: #334155; margin-bottom: 0.375rem;
    }
    .field input {
        width: 100%; box-sizing: border-box;
        padding: 0.625rem 0.875rem;
        border: 1px solid #cbd5e1; border-radius: 0.5rem;
        font-size: 0.9375rem; color: #1e293b; background: white;
        outline: none; transition: border-color 0.15s, box-shadow 0.15s;
    }
    .field input::placeholder { color: #94a3b8; }
    .field input:focus {
        border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
    }
    .field-error { color: #e11d48; font-size: 0.75rem; margin-top: 0.25rem; display: block; }
    .field .with-eye { position: relative; }
    .field .with-eye input { padding-right: 2.5rem; }
    .field .eye-btn { position: absolute; right: 0.5rem; top: 50%; transform: translateY(-50%);
        background: transparent; border: 0; cursor: pointer; color: #64748b; padding: 0.375rem;
        display: flex; align-items: center; justify-content: center; }
    .field .eye-btn:hover { color: #4f46e5; }

    .row-2 { display: grid; grid-template-columns: 1fr; gap: 1rem; }
    @@media (min-width: 480px) { .row-2 { grid-template-columns: 1fr 1fr; } }

    .terms { font-size: 0.75rem; color: #64748b; margin: 0.25rem 0 1rem; }

    .btn-primary {
        width: 100%; padding: 0.75rem; border: 0; border-radius: 0.5rem;
        color: white; font-weight: 600; font-size: 0.9375rem;
        cursor: pointer; transition: filter 0.15s;
        background: linear-gradient(90deg, #4f46e5, #4338ca);
        box-shadow: 0 10px 20px rgba(79,70,229,0.25);
    }
    .btn-primary:hover { filter: brightness(0.95); }

    .auth-foot {
        margin-top: 1.5rem; padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
        text-align: center; font-size: 0.875rem; color: #475569;
    }
    .auth-foot a { color: #4f46e5; font-weight: 600; text-decoration: none; }
    .auth-foot a:hover { color: #4338ca; }

    .validation-summary-errors {
        background: #fff1f2; border: 1px solid #fecdd3;
        color: #be123c; font-size: 0.875rem;
        padding: 0.625rem 0.875rem; border-radius: 0.5rem;
        margin-bottom: 1rem;
    }
    .validation-summary-errors ul { margin: 0; padding-left: 1.25rem; }
</style>

<div class="auth-wrap">
    <div class="auth-brand">
        <div class="auth-brand-inner">
            <div class="brand-logo">
                <div class="dollar">$</div>
                <div>
                    <div class="title">Gestor Financiero</div>
                    <div class="subtitle">Tu dinero, bajo control</div>
                </div>
            </div>

            <div>
                <h2 class="brand-headline">Toma el control<br />de tus finanzas</h2>
                <p class="brand-sub">Registra ingresos, planea presupuestos y elimina deudas — todo en un solo lugar.</p>
                <ul class="brand-list">
                    <li>
                        <div class="ico"><i class="icon-target"></i></div>
                        <div>
                            <div class="h">Presupuestos mensuales</div>
                            <div class="p">Compará lo estimado vs lo gastado en tiempo real.</div>
                        </div>
                    </li>
                    <li>
                        <div class="ico"><i class="icon-credit-card"></i></div>
                        <div>
                            <div class="h">Amortización de deudas</div>
                            <div class="p">Mirá cuánto va a capital y cuánto a interés en cada pago.</div>
                        </div>
                    </li>
                    <li>
                        <div class="ico"><i class="icon-chart-column"></i></div>
                        <div>
                            <div class="h">Reportes imprimibles</div>
                            <div class="p">Exportá a PDF desde tu navegador con un clic.</div>
                        </div>
                    </li>
                </ul>
            </div>

            <div class="brand-foot">Tus datos están protegidos. Las contraseñas se guardan hasheadas con PBKDF2.</div>
        </div>
    </div>

    <div class="auth-form">
        <div class="auth-card">
            <div class="auth-mobile-header">
                <div class="logo">$</div>
                <h1>Gestor Financiero</h1>
            </div>

            <div class="auth-box">
                <h2>Crear cuenta</h2>
                <p class="sub">Empieza a gestionar tus finanzas en menos de un minuto.</p>

                @using (Html.BeginForm("Register", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)

                    <div class="field">
                        <label>Nombre completo</label>
                        @Html.TextBoxFor(m => m.Nombre, new { placeholder = "Tu nombre" })
                        @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "field-error" })
                    </div>

                    <div class="field">
                        <label>Correo electrónico</label>
                        @Html.TextBoxFor(m => m.Email, new { type = "email", placeholder = "tu@email.com" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "field-error" })
                    </div>

                    <div class="row-2">
                        <div class="field">
                            <label>Contraseña</label>
                            <div class="with-eye">
                                @Html.PasswordFor(m => m.Password, new { id = "regPwd1", placeholder = "Mín. 8" })
                                <button type="button" class="eye-btn" data-target="regPwd1" aria-label="Mostrar/ocultar">
                                    <i class="icon-eye"></i>
                                </button>
                            </div>
                            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "field-error" })
                        </div>
                        <div class="field">
                            <label>Confirmar</label>
                            <div class="with-eye">
                                @Html.PasswordFor(m => m.ConfirmPassword, new { id = "regPwd2", placeholder = "Repetir" })
                                <button type="button" class="eye-btn" data-target="regPwd2" aria-label="Mostrar/ocultar">
                                    <i class="icon-eye"></i>
                                </button>
                            </div>
                            @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "field-error" })
                        </div>
                    </div>

                    <p class="terms">Al continuar aceptás la política de privacidad y el manejo seguro de tus datos.</p>

                    <button type="submit" class="btn-primary">Crear cuenta</button>
                }

                <div class="auth-foot">
                    ¿Ya tienes cuenta? <a href="@Url.Action("Login")">Iniciá sesión</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.eye-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var input = document.getElementById(btn.dataset.target);
            if (!input) return;
            var ico = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                if (ico) { ico.classList.remove('icon-eye'); ico.classList.add('icon-eye-off'); }
            } else {
                input.type = 'password';
                if (ico) { ico.classList.remove('icon-eye-off'); ico.classList.add('icon-eye'); }
            }
        });
    });
</script>
