@model gestor_financiero.Models.PagoDeuda
@{ ViewBag.Title = "Registrar pago"; }

<div class="max-w-2xl bg-white rounded-xl shadow-sm border border-slate-100 p-6">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-rose-600 text-sm block mb-2" })
        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Deuda</label>
                @Html.DropDownList("IdDeuda", (SelectList)ViewBag.IdDeuda, "Seleccione...", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg" })
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Fecha</label>
                @Html.TextBoxFor(m => m.Fecha, "{0:yyyy-MM-dd}", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "date" })
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Pago mínimo</label>
                    @Html.TextBoxFor(m => m.PagoMinimo, "{0:F2}", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "number", step = "0.01" })
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Pago extra</label>
                    @Html.TextBoxFor(m => m.PagoExtra, "{0:F2}", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "number", step = "0.01" })
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3 p-4 bg-slate-50 rounded-lg">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Interés del periodo</label>
                    @Html.TextBoxFor(m => m.Interes, "{0:F2}", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "number", step = "0.01" })
                    <p class="text-xs text-slate-500 mt-1">Cuánto se va a intereses</p>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">A capital</label>
                    @Html.TextBoxFor(m => m.Capital, "{0:F2}", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "number", step = "0.01" })
                    <p class="text-xs text-slate-500 mt-1">Cuánto reduce la deuda</p>
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Saldo restante (opcional)</label>
                @Html.TextBoxFor(m => m.SaldoRestante, "{0:F2}", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "number", step = "0.01", placeholder = "Se calcula automáticamente si lo dejas vacío" })
            </div>
        </div>
        <div class="flex gap-2 pt-4">
            <button type="submit" class="px-5 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg font-medium">Registrar pago</button>
            <a href="@Url.Action("Index", "Deuda")" class="px-5 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg font-medium">Cancelar</a>
        </div>
    }
</div>
