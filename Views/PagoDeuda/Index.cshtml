@model IEnumerable<gestor_financiero.Models.PagoDeuda>
@using System.Globalization
@{
    ViewBag.Title = "Pagos de deudas";
    Func<decimal, string> money = v => v.ToString("C2", new CultureInfo("es-SV"));
    var idDeuda = ViewBag.IdDeuda as int?;
}

<div class="flex justify-between items-center mb-4 flex-wrap gap-3">
    <div>
        @if (idDeuda.HasValue)
        {
            <a href="@Url.Action("Details", "Deuda", new { id = idDeuda })" class="text-sm text-indigo-600 hover:text-indigo-700">← Volver al detalle de la deuda</a>
        }
    </div>
    <a href="@Url.Action("Create", new { idDeuda = idDeuda })" class="inline-flex items-center gap-1 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-sm font-medium">
        <i class="icon-plus"></i> Nuevo pago
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-x-auto">
    <table class="w-full min-w-[700px] text-sm">
        <thead class="bg-slate-50 text-slate-600 text-xs uppercase tracking-wide">
            <tr>
                <th class="text-left px-6 py-3 font-medium">Fecha</th>
                <th class="text-left px-6 py-3 font-medium">Deuda</th>
                <th class="text-right px-6 py-3 font-medium">Pago mínimo</th>
                <th class="text-right px-6 py-3 font-medium">Extra</th>
                <th class="text-right px-6 py-3 font-medium">Interés</th>
                <th class="text-right px-6 py-3 font-medium">Capital</th>
                <th class="text-right px-6 py-3 font-medium">Saldo</th>
                <th class="text-right px-6 py-3 font-medium">Acciones</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            @if (!Model.Any())
            {
                <tr><td colspan="8" class="px-6 py-12 text-center text-slate-400">No hay pagos registrados</td></tr>
            }
            @foreach (var p in Model)
            {
                var nombreDeuda = p.Deuda != null ? p.Deuda.Nombre : "";
                <tr class="hover:bg-slate-50">
                    <td class="px-6 py-3">@p.Fecha.ToString("dd MMM yyyy", new CultureInfo("es"))</td>
                    <td class="px-6 py-3">@nombreDeuda</td>
                    <td class="px-6 py-3 text-right">@money(p.PagoMinimo)</td>
                    <td class="px-6 py-3 text-right text-emerald-600">@money(p.PagoExtra)</td>
                    <td class="px-6 py-3 text-right text-rose-600">@money(p.Interes)</td>
                    <td class="px-6 py-3 text-right font-medium">@money(p.Capital)</td>
                    <td class="px-6 py-3 text-right font-semibold">@(p.SaldoRestante.HasValue ? money(p.SaldoRestante.Value) : "—")</td>
                    <td class="px-6 py-3 text-right">
                        <a href="@Url.Action("Edit", new { id = p.IdPago })" class="text-indigo-600 hover:text-indigo-700"><i class="icon-pencil"></i></a>
                        <a href="@Url.Action("Delete", new { id = p.IdPago })" class="text-rose-600 hover:text-rose-700 ml-3"><i class="icon-trash-2"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
