@model IEnumerable<gestor_financiero.Models.Presupuesto>
@using System.Globalization
@{ ViewBag.Title = "Presupuestos"; }

<div class="flex justify-end mb-4">
    <a href="@Url.Action("Create")" class="inline-flex items-center gap-1 px-4 py-2 bg-brand-600 hover:bg-brand-700 text-white rounded-lg text-sm font-medium">
        <i class="lucide lucide-plus"></i> Nuevo presupuesto
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    @foreach (var p in Model)
    {
        var nombreMes = CultureInfo.GetCultureInfo("es").DateTimeFormat.GetMonthName(p.Mes);
        <a href="@Url.Action("Details", new { id = p.IdPresupuesto })" class="block bg-white rounded-xl shadow-sm border border-slate-100 p-5 hover:shadow-md hover:-translate-y-0.5 transition-all">
            <div class="flex items-start justify-between mb-3">
                <div>
                    <div class="text-2xl font-bold text-slate-800 capitalize">@nombreMes</div>
                    <div class="text-sm text-slate-500">@p.Anio · @p.Usuario?.Nombre</div>
                </div>
                <div class="w-10 h-10 bg-brand-100 text-brand-600 rounded-lg flex items-center justify-center">
                    <i class="lucide lucide-target"></i>
                </div>
            </div>
            <div class="text-xs text-brand-600 font-medium">Ver detalle →</div>
        </a>
    }
    @if (!Model.Any())
    {
        <div class="col-span-full bg-white rounded-xl shadow-sm border border-slate-100 p-12 text-center text-slate-400">
            Aún no has creado presupuestos
        </div>
    }
</div>
