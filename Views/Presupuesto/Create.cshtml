@model gestor_financiero.Models.Presupuesto
@{ ViewBag.Title = "Nuevo presupuesto"; }

<div class="max-w-xl bg-white rounded-xl shadow-sm border border-slate-100 p-6">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-rose-600 text-sm block mb-2" })
        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Usuario</label>
                @Html.DropDownList("IdUsuario", (SelectList)ViewBag.IdUsuario, "Seleccione...", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg" })
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Año</label>
                    @Html.TextBoxFor(m => m.Anio, new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "number", min = 2000, max = 2100, value = DateTime.Now.Year })
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Mes</label>
                    <select name="Mes" class="w-full px-3 py-2 border border-slate-300 rounded-lg">
                        @for (int m = 1; m <= 12; m++)
                        {
                            <option value="@m" selected="@(m == DateTime.Now.Month)">@System.Globalization.CultureInfo.GetCultureInfo("es").DateTimeFormat.GetMonthName(m)</option>
                        }
                    </select>
                </div>
            </div>
        </div>
        <div class="flex gap-2 pt-4">
            <button type="submit" class="px-5 py-2 bg-brand-600 hover:bg-brand-700 text-white rounded-lg font-medium">Crear</button>
            <a href="@Url.Action("Index")" class="px-5 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg font-medium">Cancelar</a>
        </div>
    }
</div>
