@model IEnumerable<gestor_financiero.Models.ResumenAnual>
@using System.Globalization
@{
    ViewBag.Title = "Resumen Anual";
    Func<decimal, string> money = v => v.ToString("C2", new CultureInfo("es-SV"));
}

<div class="flex justify-end mb-4">
    <a href="@Url.Action("Create")" class="inline-flex items-center gap-1 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-sm font-medium">
        <i class="icon-plus"></i> Nuevo resumen
    </a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
        <h3 class="font-semibold text-slate-800 mb-4">Comparativa anual</h3>
        <canvas id="chartAnual" height="120"></canvas>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
        <h3 class="font-semibold text-slate-800 mb-4">Distribución promedio</h3>
        <canvas id="chartDistribucion"></canvas>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 text-slate-600 text-xs uppercase tracking-wide">
            <tr>
                <th class="text-left px-6 py-3 font-medium">Año</th>
                <th class="text-left px-6 py-3 font-medium">Usuario</th>
                <th class="text-right px-6 py-3 font-medium">Ingresos</th>
                <th class="text-right px-6 py-3 font-medium">Ahorros</th>
                <th class="text-right px-6 py-3 font-medium">Gastos fijos</th>
                <th class="text-right px-6 py-3 font-medium">Gastos var.</th>
                <th class="text-right px-6 py-3 font-medium">Deudas</th>
                <th class="text-right px-6 py-3 font-medium">Balance</th>
                <th></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            @foreach (var r in Model)
            {
                var balance = (r.Ingresos ?? 0) - (r.GastosFijos ?? 0) - (r.GastosVariables ?? 0) - (r.Deudas ?? 0);
                <tr class="hover:bg-slate-50">
                    <td class="px-6 py-3 font-semibold">@r.Anio</td>
                    <td class="px-6 py-3">@(r.Usuario != null ? r.Usuario.Nombre : "")</td>
                    <td class="px-6 py-3 text-right text-emerald-600">@money(r.Ingresos ?? 0)</td>
                    <td class="px-6 py-3 text-right text-sky-600">@money(r.Ahorros ?? 0)</td>
                    <td class="px-6 py-3 text-right">@money(r.GastosFijos ?? 0)</td>
                    <td class="px-6 py-3 text-right">@money(r.GastosVariables ?? 0)</td>
                    <td class="px-6 py-3 text-right text-rose-600">@money(r.Deudas ?? 0)</td>
                    <td class="px-6 py-3 text-right font-bold @(balance >= 0 ? "text-emerald-600" : "text-rose-600")">@money(balance)</td>
                    <td class="px-6 py-3 text-right">
                        <a href="@Url.Action("Edit", new { id = r.IdResumen })" class="text-indigo-600"><i class="icon-pencil text-sm"></i></a>
                        <a href="@Url.Action("Delete", new { id = r.IdResumen })" class="text-rose-600 ml-2"><i class="icon-trash-2 text-sm"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script src="~/Scripts/chart.umd.min.js"></script>
<script>
    const data = @Html.Raw(System.Web.Helpers.Json.Encode(Model.Select(r => new {
        anio = r.Anio,
        ingresos = r.Ingresos ?? 0,
        ahorros = r.Ahorros ?? 0,
        gastosFijos = r.GastosFijos ?? 0,
        gastosVariables = r.GastosVariables ?? 0,
        deudas = r.Deudas ?? 0
    })));

    if (data.length) {
        new Chart(document.getElementById('chartAnual'), {
            type: 'bar',
            data: {
                labels: data.map(d => d.anio),
                datasets: [
                    { label: 'Ingresos', data: data.map(d => d.ingresos), backgroundColor: '#10b981' },
                    { label: 'Gastos Fijos', data: data.map(d => d.gastosFijos), backgroundColor: '#f59e0b' },
                    { label: 'Gastos Variables', data: data.map(d => d.gastosVariables), backgroundColor: '#f43f5e' },
                    { label: 'Deudas', data: data.map(d => d.deudas), backgroundColor: '#8b5cf6' }
                ]
            },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } }, scales: { y: { beginAtZero: true } } }
        });

        const totals = data.reduce((a,d) => ({
            ahorros: a.ahorros + d.ahorros,
            gastosFijos: a.gastosFijos + d.gastosFijos,
            gastosVariables: a.gastosVariables + d.gastosVariables,
            deudas: a.deudas + d.deudas
        }), { ahorros: 0, gastosFijos: 0, gastosVariables: 0, deudas: 0 });

        new Chart(document.getElementById('chartDistribucion'), {
            type: 'pie',
            data: {
                labels: ['Ahorros','Gastos Fijos','Gastos Variables','Deudas'],
                datasets: [{
                    data: [totals.ahorros, totals.gastosFijos, totals.gastosVariables, totals.deudas],
                    backgroundColor: ['#0ea5e9','#f59e0b','#f43f5e','#8b5cf6']
                }]
            },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
        });
    }
</script>
}
