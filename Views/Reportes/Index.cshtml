@{ ViewBag.Title = "Reportes"; }

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    @{
        var cards = new[] {
            new { Title = "Transacciones", Desc = "Detalle de movimientos en un rango de fechas.", Action = "Transacciones", Color = "brand", Icon = "icon-arrow-right-left" },
            new { Title = "Deudas", Desc = "Estado de cada deuda y total adeudado.",                Action = "Deudas",        Color = "rose",  Icon = "icon-credit-card" },
            new { Title = "Presupuesto", Desc = "Comparativa estimado vs real por categoría.",     Action = "Presupuesto",   Color = "amber", Icon = "icon-target" },
            new { Title = "Resumen Anual", Desc = "Visión macro de ingresos, ahorros y deudas.",   Action = "ResumenAnual",  Color = "emerald", Icon = "icon-chart-column" }
        };
    }
    @foreach (var c in cards)
    {
        <a href="@Url.Action(c.Action)" class="group bg-white rounded-xl shadow-sm border border-slate-100 p-6 hover:shadow-md hover:-translate-y-0.5 transition-all">
            <div class="w-12 h-12 bg-@(c.Color)-100 text-@(c.Color)-600 rounded-xl flex items-center justify-center mb-4">
                <i class="@c.Icon text-xl"></i>
            </div>
            <h3 class="font-semibold text-slate-800 mb-1">@c.Title</h3>
            <p class="text-sm text-slate-500 mb-3">@c.Desc</p>
            <span class="text-xs text-indigo-600 group-hover:text-indigo-700 font-medium">Ver reporte →</span>
        </a>
    }
</div>

<div class="mt-6 p-4 bg-sky-50 border border-sky-200 rounded-lg text-sm text-sky-800">
    <i class="icon-info"></i>
    Para exportar a PDF: abre el reporte y usa <strong>Imprimir → Guardar como PDF</strong> del navegador.
    Para PDFs generados desde el servidor, instala el paquete NuGet <code class="bg-white px-1 rounded">Rotativa</code> y descomenta las acciones PDF en <code class="bg-white px-1 rounded">ReportesController.cs</code>.
</div>
