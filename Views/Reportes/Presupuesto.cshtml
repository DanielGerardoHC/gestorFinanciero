@model gestor_financiero.Models.Presupuesto
@using System.Globalization
@{
    ViewBag.Title = "Reporte de presupuesto";
    Func<decimal, string> money = v => v.ToString("C2", new CultureInfo("es-SV"));
    if (Model == null) { <p class="text-slate-500">Sin presupuestos para reportar.</p>; return; }
    var nombreMes = CultureInfo.GetCultureInfo("es").DateTimeFormat.GetMonthName(Model.Mes);
    var totalE = Model.Detalles?.Sum(d => d.Estimado) ?? 0;
    var totalR = Model.Detalles?.Sum(d => d.Real) ?? 0;
}

@section Styles {
    <style>@@media print { aside, header, .no-print { display: none !important; } main { padding: 0 !important; } body { background: white !important; } }</style>
}

<div class="no-print flex justify-end gap-2 mb-4">
    <button onclick="window.print()" class="px-4 py-2 bg-slate-200 hover:bg-slate-300 text-slate-700 rounded-lg text-sm font-medium inline-flex items-center gap-1">
        <i class="icon-printer"></i> Imprimir
    </button>
    <button type="button" id="btnPdf" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-medium inline-flex items-center gap-1">
        <i class="icon-download"></i> Descargar PDF
    </button>
</div>

<div id="reporte-pdf" class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 print:shadow-none print:border-0">
    <div class="flex items-center justify-between mb-6 pb-4 border-b border-slate-200">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Reporte de Presupuesto</h1>
            <p class="text-sm text-slate-500 capitalize">@nombreMes @Model.Anio</p>
        </div>
        <div class="text-right">
            <div class="text-xs text-slate-500">Real / Estimado</div>
            <div class="text-xl font-bold">@money(totalR) / @money(totalE)</div>
        </div>
    </div>

    <table class="w-full min-w-[700px] text-sm">
        <thead class="border-b-2 border-slate-300 text-slate-700">
            <tr>
                <th class="text-left py-2">Categoría</th>
                <th class="text-left py-2">Tipo</th>
                <th class="text-right py-2">Estimado</th>
                <th class="text-right py-2">Real</th>
                <th class="text-right py-2">Diferencia</th>
                <th class="text-right py-2">% Uso</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model.Detalles ?? new List<gestor_financiero.Models.PresupuestoDetalle>())
            {
                var diff = d.Estimado - d.Real;
                var pct = d.Estimado > 0 ? (double)(d.Real / d.Estimado) * 100 : 0;
                var nombreCat = d.Categoria != null ? d.Categoria.Nombre : "";
                var tipoCat = d.Categoria != null ? d.Categoria.Tipo : "";
                <tr class="border-b border-slate-100">
                    <td class="py-2 font-medium">@nombreCat</td>
                    <td class="py-2 text-xs text-slate-500">@tipoCat</td>
                    <td class="py-2 text-right">@money(d.Estimado)</td>
                    <td class="py-2 text-right">@money(d.Real)</td>
                    <td class="py-2 text-right @(diff < 0 ? "text-rose-600" : "text-emerald-600")">@money(diff)</td>
                    <td class="py-2 text-right">@pct.ToString("0")%</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script src="~/Scripts/html2pdf.min.js"></script>
<script>
    document.getElementById('btnPdf').addEventListener('click', function () {
        var el = document.getElementById('reporte-pdf');
        var nombre = 'Reporte_Presupuesto_@(nombreMes)_@(Model.Anio).pdf';

        if (window.Swal) {
            Swal.fire({
                title: 'Generando PDF…',
                allowOutsideClick: false,
                didOpen: function () { Swal.showLoading(); }
            });
        }

        html2pdf().set({
            margin:      [10, 10, 10, 10],
            filename:    nombre,
            image:       { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2, useCORS: true, backgroundColor: '#ffffff' },
            jsPDF:       { unit: 'mm', format: 'a4', orientation: 'portrait' },
            pagebreak:   { mode: ['avoid-all', 'css', 'legacy'] }
        }).from(el).save().then(function () {
            if (window.Swal) Swal.close();
        }).catch(function (err) {
            if (window.Swal) { Swal.close(); Swal.fire('Error', 'No se pudo generar el PDF', 'error'); }
            console.error(err);
        });
    });
</script>
}
