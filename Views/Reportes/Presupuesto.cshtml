@model gestor_financiero.Models.Presupuesto
@using System.Globalization
@{
    ViewBag.Title = "Reporte de presupuesto";
    Func<decimal, string> money = v => v.ToString("C2", new CultureInfo("es-SV"));
    if (Model == null) { <p class="text-slate-500">Sin presupuestos para reportar.</p>; return; }
    var nombreMes = CultureInfo.GetCultureInfo("es").DateTimeFormat.GetMonthName(Model.Mes);
    var totalE = Model.Detalles?.Sum(d => d.Estimado) ?? 0;
    var totalR = Model.Detalles?.Sum(d => d.Real) ?? 0;
}

@section Styles {
    <style>@@media print { aside, header, .no-print { display: none !important; } main { padding: 0 !important; } body { background: white !important; } }</style>
}

<div class="no-print flex justify-end mb-4">
    <button onclick="window.print()" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-medium inline-flex items-center gap-1">
        <i class="lucide lucide-printer"></i> Imprimir / PDF
    </button>
</div>

<div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 print:shadow-none print:border-0">
    <div class="flex items-center justify-between mb-6 pb-4 border-b border-slate-200">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Reporte de Presupuesto</h1>
            <p class="text-sm text-slate-500 capitalize">@nombreMes @Model.Anio · @Model.Usuario?.Nombre</p>
        </div>
        <div class="text-right">
            <div class="text-xs text-slate-500">Real / Estimado</div>
            <div class="text-xl font-bold">@money(totalR) / @money(totalE)</div>
        </div>
    </div>

    <table class="w-full text-sm">
        <thead class="border-b-2 border-slate-300 text-slate-700">
            <tr>
                <th class="text-left py-2">Categoría</th>
                <th class="text-left py-2">Tipo</th>
                <th class="text-right py-2">Estimado</th>
                <th class="text-right py-2">Real</th>
                <th class="text-right py-2">Diferencia</th>
                <th class="text-right py-2">% Uso</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model.Detalles ?? new List<gestor_financiero.Models.PresupuestoDetalle>())
            {
                var diff = d.Estimado - d.Real;
                var pct = d.Estimado > 0 ? (double)(d.Real / d.Estimado) * 100 : 0;
                <tr class="border-b border-slate-100">
                    <td class="py-2 font-medium">@d.Categoria?.Nombre</td>
                    <td class="py-2 text-xs text-slate-500">@d.Categoria?.Tipo</td>
                    <td class="py-2 text-right">@money(d.Estimado)</td>
                    <td class="py-2 text-right">@money(d.Real)</td>
                    <td class="py-2 text-right @(diff < 0 ? "text-rose-600" : "text-emerald-600")">@money(diff)</td>
                    <td class="py-2 text-right">@pct.ToString("0")%</td>
                </tr>
            }
        </tbody>
    </table>
</div>
