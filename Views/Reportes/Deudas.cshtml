@model IEnumerable<gestor_financiero.Models.Deuda>
@using System.Globalization
@{
    ViewBag.Title = "Reporte de deudas";
    Func<decimal, string> money = v => v.ToString("C2", new CultureInfo("es-SV"));
    var total = Model.Sum(d => d.SaldoActual);
}

@section Styles {
    <style>@@media print { aside, header, .no-print { display: none !important; } main { padding: 0 !important; } body { background: white !important; } }</style>
}

<div class="no-print flex justify-end mb-4">
    <button onclick="window.print()" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-medium inline-flex items-center gap-1">
        <i class="lucide lucide-printer"></i> Imprimir / PDF
    </button>
</div>

<div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 print:shadow-none print:border-0">
    <div class="flex items-center justify-between mb-6 pb-4 border-b border-slate-200">
        <h1 class="text-2xl font-bold text-slate-800">Reporte de Deudas</h1>
        <div class="text-right">
            <div class="text-xs text-slate-500">Total adeudado</div>
            <div class="text-2xl font-bold text-rose-600">@money(total)</div>
        </div>
    </div>

    @foreach (var d in Model)
    {
        var totalPagado = d.Pagos?.Sum(p => p.PagoMinimo + p.PagoExtra) ?? 0;
        <div class="mb-6 pb-6 border-b border-slate-100">
            <div class="flex items-center justify-between mb-2">
                <h2 class="font-semibold text-slate-800">@d.Nombre</h2>
                <span class="font-bold text-rose-600">@money(d.SaldoActual)</span>
            </div>
            <div class="grid grid-cols-4 gap-3 text-sm mb-2">
                <div><span class="text-slate-500">Tasa:</span> @(d.TasaInteres?.ToString("0.00") ?? "—")%</div>
                <div><span class="text-slate-500">Pago mín:</span> @(d.PagoMinimo.HasValue ? money(d.PagoMinimo.Value) : "—")</div>
                <div><span class="text-slate-500">Pagos:</span> @(d.Pagos?.Count ?? 0)</div>
                <div><span class="text-slate-500">Total pagado:</span> @money(totalPagado)</div>
            </div>
            @if (!string.IsNullOrEmpty(d.Notas))
            {
                <div class="text-xs italic text-slate-500">@d.Notas</div>
            }
        </div>
    }
</div>
