@model IEnumerable<gestor_financiero.Models.Deuda>
@using System.Globalization
@{
    ViewBag.Title = "Reporte de deudas";
    Func<decimal, string> money = v => v.ToString("C2", new CultureInfo("es-SV"));
    var total = Model.Sum(d => d.SaldoActual);
}

@section Styles {
    <style>@@media print { aside, header, .no-print { display: none !important; } main { padding: 0 !important; } body { background: white !important; } }</style>
}

<div class="no-print flex justify-end gap-2 mb-4">
    <button onclick="window.print()" class="px-4 py-2 bg-slate-200 hover:bg-slate-300 text-slate-700 rounded-lg text-sm font-medium inline-flex items-center gap-1">
        <i class="icon-printer"></i> Imprimir
    </button>
    <button type="button" id="btnPdf" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-medium inline-flex items-center gap-1">
        <i class="icon-download"></i> Descargar PDF
    </button>
</div>

<div id="reporte-pdf" class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 print:shadow-none print:border-0">
    <div class="flex items-center justify-between mb-6 pb-4 border-b border-slate-200">
        <h1 class="text-2xl font-bold text-slate-800">Reporte de Deudas</h1>
        <div class="text-right">
            <div class="text-xs text-slate-500">Total adeudado</div>
            <div class="text-2xl font-bold text-rose-600">@money(total)</div>
        </div>
    </div>

    @foreach (var d in Model)
    {
        var totalPagado = d.Pagos?.Sum(p => p.PagoMinimo + p.PagoExtra) ?? 0;
        <div class="mb-6 pb-6 border-b border-slate-100">
            <div class="flex items-center justify-between mb-2">
                <h2 class="font-semibold text-slate-800">@d.Nombre</h2>
                <span class="font-bold text-rose-600">@money(d.SaldoActual)</span>
            </div>
            <div class="grid grid-cols-4 gap-3 text-sm mb-2">
                <div><span class="text-slate-500">Tasa:</span> @(d.TasaInteres?.ToString("0.00") ?? "—")%</div>
                <div><span class="text-slate-500">Pago mín:</span> @(d.PagoMinimo.HasValue ? money(d.PagoMinimo.Value) : "—")</div>
                <div><span class="text-slate-500">Pagos:</span> @(d.Pagos?.Count ?? 0)</div>
                <div><span class="text-slate-500">Total pagado:</span> @money(totalPagado)</div>
            </div>
            @if (!string.IsNullOrEmpty(d.Notas))
            {
                <div class="text-xs italic text-slate-500">@d.Notas</div>
            }
        </div>
    }
</div>

@section Scripts {
<script src="~/Scripts/html2pdf.min.js"></script>
<script>
    document.getElementById('btnPdf').addEventListener('click', function () {
        var el = document.getElementById('reporte-pdf');
        var fecha = new Date().toISOString().slice(0, 10);
        var nombre = 'Reporte_Deudas_' + fecha + '.pdf';

        if (window.Swal) {
            Swal.fire({
                title: 'Generando PDF…',
                allowOutsideClick: false,
                didOpen: function () { Swal.showLoading(); }
            });
        }

        html2pdf().set({
            margin:      [10, 10, 10, 10],
            filename:    nombre,
            image:       { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2, useCORS: true, backgroundColor: '#ffffff' },
            jsPDF:       { unit: 'mm', format: 'a4', orientation: 'portrait' },
            pagebreak:   { mode: ['avoid-all', 'css', 'legacy'] }
        }).from(el).save().then(function () {
            if (window.Swal) Swal.close();
        }).catch(function (err) {
            if (window.Swal) { Swal.close(); Swal.fire('Error', 'No se pudo generar el PDF', 'error'); }
            console.error(err);
        });
    });
</script>
}
