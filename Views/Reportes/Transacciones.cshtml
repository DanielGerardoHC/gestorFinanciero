@model IEnumerable<gestor_financiero.Models.Transaccion>
@using System.Globalization
@{
    ViewBag.Title = "Reporte de transacciones";
    Func<decimal, string> money = v => v.ToString("C2", new CultureInfo("es-SV"));
    var desde = (DateTime)ViewBag.Desde;
    var hasta = (DateTime)ViewBag.Hasta;
    var ingresos = Model.Where(t => t.Categoria.Tipo == "INGRESO").Sum(t => t.Monto);
    var gastos = Model.Where(t => t.Categoria.Tipo == "GASTO_FIJO" || t.Categoria.Tipo == "GASTO_VARIABLE").Sum(t => t.Monto);
}

@section Styles {
    <style>
        @@media print {
            aside, header, .no-print { display: none !important; }
            main { padding: 0 !important; }
            body { background: white !important; }
        }
    </style>
}

@using (Html.BeginForm("Transacciones", "Reportes", FormMethod.Get, new { @class = "no-print bg-white rounded-xl shadow-sm border border-slate-100 p-4 mb-4 flex gap-3 items-end flex-wrap" }))
{
    <div><label class="block text-xs font-medium text-slate-600 mb-1">Desde</label><input type="date" name="desde" value="@desde.ToString("yyyy-MM-dd")" class="px-3 py-2 border border-slate-300 rounded-lg text-sm" /></div>
    <div><label class="block text-xs font-medium text-slate-600 mb-1">Hasta</label><input type="date" name="hasta" value="@hasta.ToString("yyyy-MM-dd")" class="px-3 py-2 border border-slate-300 rounded-lg text-sm" /></div>
    <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-700 text-white rounded-lg text-sm font-medium">Aplicar</button>
    <button type="button" onclick="window.print()" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-medium inline-flex items-center gap-1">
        <i class="lucide lucide-printer"></i> Imprimir / PDF
    </button>
}

<div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 print:shadow-none print:border-0">
    <div class="flex items-center justify-between mb-6 pb-4 border-b border-slate-200">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Reporte de Transacciones</h1>
            <p class="text-sm text-slate-500">Periodo: @desde.ToString("dd MMM yyyy", new CultureInfo("es")) – @hasta.ToString("dd MMM yyyy", new CultureInfo("es"))</p>
        </div>
        <div class="text-right text-xs text-slate-500">Generado @DateTime.Now.ToString("dd MMM yyyy HH:mm")</div>
    </div>

    <div class="grid grid-cols-3 gap-3 mb-6">
        <div class="border border-slate-200 rounded-lg p-3">
            <div class="text-xs text-slate-500">Ingresos</div>
            <div class="text-xl font-bold text-emerald-600">@money(ingresos)</div>
        </div>
        <div class="border border-slate-200 rounded-lg p-3">
            <div class="text-xs text-slate-500">Gastos</div>
            <div class="text-xl font-bold text-rose-600">@money(gastos)</div>
        </div>
        <div class="border border-slate-200 rounded-lg p-3">
            <div class="text-xs text-slate-500">Balance</div>
            <div class="text-xl font-bold @(ingresos - gastos >= 0 ? "text-emerald-600" : "text-rose-600")">@money(ingresos - gastos)</div>
        </div>
    </div>

    <table class="w-full text-sm">
        <thead class="border-b-2 border-slate-300 text-slate-700">
            <tr>
                <th class="text-left py-2">Fecha</th>
                <th class="text-left py-2">Categoría</th>
                <th class="text-left py-2">Tipo</th>
                <th class="text-left py-2">Notas</th>
                <th class="text-right py-2">Monto</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model)
            {
                <tr class="border-b border-slate-100">
                    <td class="py-2">@t.Fecha.ToString("dd/MM/yyyy")</td>
                    <td class="py-2">@t.Categoria?.Nombre</td>
                    <td class="py-2 text-xs text-slate-500">@t.Categoria?.Tipo</td>
                    <td class="py-2 text-slate-500">@t.Notas</td>
                    <td class="py-2 text-right font-medium">@money(t.Monto)</td>
                </tr>
            }
        </tbody>
    </table>
</div>
