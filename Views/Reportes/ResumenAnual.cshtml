@model IEnumerable<gestor_financiero.Models.ResumenAnual>
@using System.Globalization
@{
    ViewBag.Title = "Reporte resumen anual";
    Func<decimal, string> money = v => v.ToString("C2", new CultureInfo("es-SV"));
}

@section Styles {
    <style>@@media print { aside, header, .no-print { display: none !important; } main { padding: 0 !important; } body { background: white !important; } }</style>
}

<div class="no-print flex justify-end gap-2 mb-4">
    <button onclick="window.print()" class="px-4 py-2 bg-slate-200 hover:bg-slate-300 text-slate-700 rounded-lg text-sm font-medium inline-flex items-center gap-1">
        <i class="icon-printer"></i> Imprimir
    </button>
    <button type="button" id="btnPdf" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-medium inline-flex items-center gap-1">
        <i class="icon-download"></i> Descargar PDF
    </button>
</div>

<div id="reporte-pdf" class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 print:shadow-none print:border-0">
    <h1 class="text-2xl font-bold text-slate-800 mb-6 pb-4 border-b border-slate-200">Reporte Resumen Anual</h1>

    <table class="w-full min-w-[700px] text-sm">
        <thead class="border-b-2 border-slate-300 text-slate-700">
            <tr>
                <th class="text-left py-2">Año</th>
                <th class="text-right py-2">Ingresos</th>
                <th class="text-right py-2">Ahorros</th>
                <th class="text-right py-2">G. Fijos</th>
                <th class="text-right py-2">G. Variables</th>
                <th class="text-right py-2">Deudas</th>
                <th class="text-right py-2">Balance</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                var balance = (r.Ingresos ?? 0) - (r.GastosFijos ?? 0) - (r.GastosVariables ?? 0) - (r.Deudas ?? 0);
                <tr class="border-b border-slate-100">
                    <td class="py-2 font-medium">@r.Anio</td>
                    <td class="py-2 text-right">@money(r.Ingresos ?? 0)</td>
                    <td class="py-2 text-right">@money(r.Ahorros ?? 0)</td>
                    <td class="py-2 text-right">@money(r.GastosFijos ?? 0)</td>
                    <td class="py-2 text-right">@money(r.GastosVariables ?? 0)</td>
                    <td class="py-2 text-right">@money(r.Deudas ?? 0)</td>
                    <td class="py-2 text-right font-bold @(balance >= 0 ? "text-emerald-600" : "text-rose-600")">@money(balance)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
<script src="~/Scripts/html2pdf.min.js"></script>
<script>
    document.getElementById('btnPdf').addEventListener('click', function () {
        var el = document.getElementById('reporte-pdf');
        var fecha = new Date().toISOString().slice(0, 10);
        var nombre = 'Reporte_ResumenAnual_' + fecha + '.pdf';

        if (window.Swal) {
            Swal.fire({
                title: 'Generando PDF…',
                allowOutsideClick: false,
                didOpen: function () { Swal.showLoading(); }
            });
        }

        html2pdf().set({
            margin:      [10, 10, 10, 10],
            filename:    nombre,
            image:       { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2, useCORS: true, backgroundColor: '#ffffff' },
            // Landscape porque la tabla del resumen anual es ancha
            jsPDF:       { unit: 'mm', format: 'a4', orientation: 'landscape' },
            pagebreak:   { mode: ['avoid-all', 'css', 'legacy'] }
        }).from(el).save().then(function () {
            if (window.Swal) Swal.close();
        }).catch(function (err) {
            if (window.Swal) { Swal.close(); Swal.fire('Error', 'No se pudo generar el PDF', 'error'); }
            console.error(err);
        });
    });
</script>
}
