@model IEnumerable<gestor_financiero.Models.Usuario>
@{ ViewBag.Title = "Usuarios"; }

<div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 text-slate-600 text-xs uppercase tracking-wide">
            <tr>
                <th class="text-left px-6 py-3 font-medium">Usuario</th>
                <th class="text-left px-6 py-3 font-medium">Email</th>
                <th class="text-left px-6 py-3 font-medium">Registrado</th>
                <th class="text-right px-6 py-3 font-medium">Acciones</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            @foreach (var u in Model)
            {
                <tr class="hover:bg-slate-50">
                    <td class="px-6 py-3">
                        <div class="flex items-center gap-3">
                            <div class="w-9 h-9 bg-gradient-to-br from-indigo-400 to-indigo-600 text-white rounded-full flex items-center justify-center font-semibold text-sm">
                                @(u.Nombre.Substring(0,1).ToUpper())
                            </div>
                            <span class="font-medium text-slate-800">@u.Nombre</span>
                        </div>
                    </td>
                    <td class="px-6 py-3 text-slate-600">@u.Email</td>
                    <td class="px-6 py-3 text-slate-500">@u.FechaRegistro.ToString("dd MMM yyyy")</td>
                    <td class="px-6 py-3 text-right">
                        <a href="@Url.Action("Edit", new { id = u.IdUsuario })" class="text-indigo-600 hover:text-indigo-700"><i class="icon-pencil"></i></a>
                        <a href="@Url.Action("Delete", new { id = u.IdUsuario })" class="text-rose-600 hover:text-rose-700 ml-3"><i class="icon-trash-2"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
