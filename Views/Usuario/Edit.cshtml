@model gestor_financiero.Models.Usuario
@{ ViewBag.Title = "Editar mi perfil"; }
<div class="max-w-xl bg-white rounded-xl shadow-sm border border-slate-100 p-6">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-rose-600 text-sm block mb-2" })
        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Nombre</label>
                @Html.TextBoxFor(m => m.Nombre, new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg" })
                @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-rose-600 text-xs mt-1 block" })
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Email</label>
                @Html.TextBoxFor(m => m.Email, new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "email" })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-rose-600 text-xs mt-1 block" })
            </div>
        </div>
        <div class="flex gap-2 pt-4">
            <button type="submit" class="px-5 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg font-medium">Guardar</button>
            <a href="@Url.Action("Index")" class="px-5 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg font-medium">Cancelar</a>
        </div>
    }
</div>
