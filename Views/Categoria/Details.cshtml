@model gestor_financiero.Models.Categoria
@{ ViewBag.Title = "Detalle de categoría"; }
<div class="max-w-md bg-white rounded-xl shadow-sm border border-slate-100 p-6">
    <dl class="grid grid-cols-2 gap-3 text-sm mb-6">
        <dt class="text-slate-500">Nombre</dt><dd class="font-medium">@Model.Nombre</dd>
        <dt class="text-slate-500">Tipo</dt><dd class="font-medium">@Model.Tipo</dd>
    </dl>
    <a href="@Url.Action("Index")" class="px-5 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg font-medium">Volver</a>
</div>
