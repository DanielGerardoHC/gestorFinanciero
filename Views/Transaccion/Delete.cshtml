@model gestor_financiero.Models.Transaccion
@using System.Globalization
@{ ViewBag.Title = "Eliminar transacción"; }

<div class="max-w-xl bg-white rounded-xl shadow-sm border border-slate-100 p-6">
    <div class="flex items-start gap-3 p-4 bg-rose-50 border border-rose-200 rounded-lg mb-4">
        <i class="lucide lucide-alert-triangle text-rose-600 text-xl"></i>
        <div>
            <p class="font-semibold text-rose-800">¿Eliminar esta transacción?</p>
            <p class="text-sm text-rose-700">Esta acción no se puede deshacer.</p>
        </div>
    </div>
    <dl class="grid grid-cols-2 gap-3 text-sm mb-6">
        <dt class="text-slate-500">Fecha</dt><dd class="font-medium">@Model.Fecha.ToString("dd MMM yyyy", new CultureInfo("es"))</dd>
        <dt class="text-slate-500">Categoría</dt><dd class="font-medium">@Model.Categoria?.Nombre</dd>
        <dt class="text-slate-500">Monto</dt><dd class="font-medium">@Model.Monto.ToString("C2", new CultureInfo("es-SV"))</dd>
        <dt class="text-slate-500">Notas</dt><dd>@Model.Notas</dd>
    </dl>
    @using (Html.BeginForm("Delete", "Transaccion"))
    {
        @Html.AntiForgeryToken()
        <div class="flex gap-2">
            <button type="submit" class="px-5 py-2 bg-rose-600 hover:bg-rose-700 text-white rounded-lg font-medium">Sí, eliminar</button>
            <a href="@Url.Action("Index")" class="px-5 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg font-medium">Cancelar</a>
        </div>
    }
</div>
