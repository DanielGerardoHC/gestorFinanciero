@model gestor_financiero.Models.Transaccion
@{ ViewBag.Title = "Editar transacción"; }

<div class="max-w-2xl bg-white rounded-xl shadow-sm border border-slate-100 p-6">
    @using (Html.BeginForm("Edit", "Transaccion", FormMethod.Post, new { @class = "space-y-4" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.IdTransaccion)
        @Html.ValidationSummary(true, "", new { @class = "text-rose-600 text-sm block" })
        @Html.Partial("_FormTransaccion", Model)
        <div class="flex gap-2 pt-2">
            <button type="submit" class="px-5 py-2 bg-brand-600 hover:bg-brand-700 text-white rounded-lg font-medium">Actualizar</button>
            <a href="@Url.Action("Index")" class="px-5 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg font-medium">Cancelar</a>
        </div>
    }
</div>
