@model IEnumerable<gestor_financiero.Models.Transaccion>
@using System.Globalization
@{
    ViewBag.Title = "Transacciones";
    Func<decimal, string> money = v => v.ToString("C2", new CultureInfo("es-SV"));

    Func<string, string> badge = tipo =>
        tipo == "INGRESO" ? "bg-emerald-100 text-emerald-700" :
        tipo == "AHORRO" ? "bg-sky-100 text-sky-700" :
        tipo == "GASTO_FIJO" ? "bg-amber-100 text-amber-700" :
        tipo == "GASTO_VARIABLE" ? "bg-rose-100 text-rose-700" :
        tipo == "DEUDA" ? "bg-violet-100 text-violet-700" :
        "bg-slate-100 text-slate-700";
}

<div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
    @using (Html.BeginForm("Index", "Transaccion", FormMethod.Get, new { @class = "px-6 py-4 border-b border-slate-100 grid grid-cols-1 md:grid-cols-4 gap-3 items-end" }))
    {
        <div>
            <label class="block text-xs font-medium text-slate-600 mb-1">Usuario</label>
            @Html.DropDownList("idUsuario", (SelectList)ViewBag.IdUsuario, "Todos", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" })
        </div>
        <div>
            <label class="block text-xs font-medium text-slate-600 mb-1">Desde</label>
            <input type="date" name="desde" value="@ViewBag.Desde" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" />
        </div>
        <div>
            <label class="block text-xs font-medium text-slate-600 mb-1">Hasta</label>
            <input type="date" name="hasta" value="@ViewBag.Hasta" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm" />
        </div>
        <div class="flex gap-2">
            <button type="submit" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-sm font-medium">Filtrar</button>
            <a href="@Url.Action("Create")" class="inline-flex items-center gap-1 px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-medium">
                <i class="icon-plus"></i> Nueva
            </a>
        </div>
    }

    <table class="w-full text-sm">
        <thead class="bg-slate-50 text-slate-600 text-xs uppercase tracking-wide">
            <tr>
                <th class="text-left px-6 py-3 font-medium">Fecha</th>
                <th class="text-left px-6 py-3 font-medium">Usuario</th>
                <th class="text-left px-6 py-3 font-medium">Categoría</th>
                <th class="text-left px-6 py-3 font-medium">Notas</th>
                <th class="text-right px-6 py-3 font-medium">Monto</th>
                <th class="text-right px-6 py-3 font-medium">Acciones</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="px-6 py-12 text-center text-slate-400">Sin transacciones que mostrar</td></tr>
            }
            @foreach (var t in Model)
            {
                var nombreUsuario = t.Usuario != null ? t.Usuario.Nombre : "";
                var nombreCategoria = t.Categoria != null ? t.Categoria.Nombre : "";
                var tipoCategoria = t.Categoria != null ? t.Categoria.Tipo : "";
                var esIngreso = tipoCategoria == "INGRESO";
                <tr class="hover:bg-slate-50">
                    <td class="px-6 py-3">@t.Fecha.ToString("dd MMM yyyy", new CultureInfo("es"))</td>
                    <td class="px-6 py-3">@nombreUsuario</td>
                    <td class="px-6 py-3">
                        <span class="inline-flex items-center gap-1.5">
                            @nombreCategoria
                            <span class="text-xs px-2 py-0.5 rounded-full @badge(tipoCategoria)">@tipoCategoria</span>
                        </span>
                    </td>
                    <td class="px-6 py-3 text-slate-500 max-w-xs truncate">@t.Notas</td>
                    <td class="px-6 py-3 text-right font-semibold @(esIngreso ? "text-emerald-600" : "text-slate-800")">
                        @money(t.Monto)
                    </td>
                    <td class="px-6 py-3 text-right">
                        <a href="@Url.Action("Edit", new { id = t.IdTransaccion })" class="text-indigo-600 hover:text-indigo-700"><i class="icon-pencil"></i></a>
                        <a href="@Url.Action("Delete", new { id = t.IdTransaccion })" class="text-rose-600 hover:text-rose-700 ml-3"><i class="icon-trash-2"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
