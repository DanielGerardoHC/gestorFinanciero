@model gestor_financiero.Models.Deuda
@using System.Globalization
@{
    ViewBag.Title = Model.Nombre;
    Func<decimal, string> money = v => v.ToString("C2", new CultureInfo("es-SV"));
    var totalPagado = Model.Pagos?.Sum(x => x.PagoMinimo + x.PagoExtra) ?? 0;
    var totalInteres = Model.Pagos?.Sum(x => x.Interes) ?? 0;
    var totalCapital = Model.Pagos?.Sum(x => x.Capital) ?? 0;
}

<div class="bg-gradient-to-r from-rose-600 to-rose-800 text-white rounded-xl p-6 mb-6 shadow-lg">
    <div class="flex items-center justify-between flex-wrap gap-4">
        <div>
            <h2 class="text-3xl font-bold">@Model.Nombre</h2>
            <p class="text-rose-100 text-sm">@(Model.Usuario != null ? Model.Usuario.Nombre : "")</p>
        </div>
        <div class="text-right">
            <div class="text-rose-200 text-xs uppercase tracking-wide">Saldo actual</div>
            <div class="text-3xl font-bold">@money(Model.SaldoActual)</div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-100">
        <div class="text-xs text-slate-500 uppercase">Tasa de interés</div>
        <div class="text-xl font-bold text-slate-800">@(Model.TasaInteres?.ToString("0.00") ?? "—")%</div>
    </div>
    <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-100">
        <div class="text-xs text-slate-500 uppercase">Pago mínimo</div>
        <div class="text-xl font-bold text-slate-800">@(Model.PagoMinimo.HasValue ? money(Model.PagoMinimo.Value) : "—")</div>
    </div>
    <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-100">
        <div class="text-xs text-slate-500 uppercase">Total pagado</div>
        <div class="text-xl font-bold text-emerald-600">@money(totalPagado)</div>
    </div>
    <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-100">
        <div class="text-xs text-slate-500 uppercase">A capital / Interés</div>
        <div class="text-xl font-bold text-slate-800">@money(totalCapital) <span class="text-sm text-rose-500">/ @money(totalInteres)</span></div>
    </div>
</div>

<div class="flex justify-between items-center mb-3">
    <h3 class="font-semibold text-slate-800">Historial de pagos</h3>
    <a href="@Url.Action("Create", "PagoDeuda", new { idDeuda = Model.IdDeuda })" class="inline-flex items-center gap-1 px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-medium">
        <i class="icon-plus"></i> Registrar pago
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 text-slate-600 text-xs uppercase tracking-wide">
            <tr>
                <th class="text-left px-6 py-3 font-medium">Fecha</th>
                <th class="text-right px-6 py-3 font-medium">Pago mínimo</th>
                <th class="text-right px-6 py-3 font-medium">Extra</th>
                <th class="text-right px-6 py-3 font-medium">Interés</th>
                <th class="text-right px-6 py-3 font-medium">Capital</th>
                <th class="text-right px-6 py-3 font-medium">Saldo</th>
                <th></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            @if (Model.Pagos == null || !Model.Pagos.Any())
            {
                <tr><td colspan="7" class="px-6 py-8 text-center text-slate-400">Sin pagos registrados</td></tr>
            }
            @foreach (var p in (Model.Pagos ?? new List<gestor_financiero.Models.PagoDeuda>()).OrderByDescending(x => x.Fecha))
            {
                <tr class="hover:bg-slate-50">
                    <td class="px-6 py-3">@p.Fecha.ToString("dd MMM yyyy", new CultureInfo("es"))</td>
                    <td class="px-6 py-3 text-right">@money(p.PagoMinimo)</td>
                    <td class="px-6 py-3 text-right text-emerald-600">@money(p.PagoExtra)</td>
                    <td class="px-6 py-3 text-right text-rose-600">@money(p.Interes)</td>
                    <td class="px-6 py-3 text-right text-slate-800 font-medium">@money(p.Capital)</td>
                    <td class="px-6 py-3 text-right font-semibold">@(p.SaldoRestante.HasValue ? money(p.SaldoRestante.Value) : "—")</td>
                    <td class="px-6 py-3 text-right">
                        <a href="@Url.Action("Edit", "PagoDeuda", new { id = p.IdPago })" class="text-indigo-600"><i class="icon-pencil text-sm"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-6"><a href="@Url.Action("Index")" class="px-5 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg font-medium inline-block">← Volver</a></div>
