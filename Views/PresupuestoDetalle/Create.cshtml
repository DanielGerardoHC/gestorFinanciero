@model gestor_financiero.Models.PresupuestoDetalle
@{ ViewBag.Title = "Agregar categoría al presupuesto"; }

<div class="max-w-xl bg-white rounded-xl shadow-sm border border-slate-100 p-6">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-rose-600 text-sm block mb-2" })
        @Html.HiddenFor(m => m.IdPresupuesto)
        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Categoría</label>
                @Html.DropDownList("IdCategoria", (SelectList)ViewBag.IdCategoria, "Seleccione...", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg" })
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Estimado</label>
                    <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">$</span>
                    @Html.TextBoxFor(m => m.Estimado, "{0:F2}", new { @class = "w-full pl-7 pr-3 py-2 border border-slate-300 rounded-lg", type = "number", step = "0.01" })</div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Real (ejecutado)</label>
                    <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">$</span>
                    @Html.TextBoxFor(m => m.Real, "{0:F2}", new { @class = "w-full pl-7 pr-3 py-2 border border-slate-300 rounded-lg", type = "number", step = "0.01" })</div>
                </div>
            </div>
        </div>
        <div class="flex gap-2 pt-4">
            <button type="submit" class="px-5 py-2 bg-brand-600 hover:bg-brand-700 text-white rounded-lg font-medium">Guardar</button>
            <a href="@Url.Action("Details", "Presupuesto", new { id = Model.IdPresupuesto })" class="px-5 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg font-medium">Cancelar</a>
        </div>
    }
</div>
