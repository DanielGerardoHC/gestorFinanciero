@model gestor_financiero.Models.Categoria

<div class="space-y-4">
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Nombre</label>
        @Html.TextBoxFor(m => m.Nombre, new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", placeholder = "Ej: Servicios públicos" })
        @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-rose-600 text-xs mt-1 block" })
    </div>
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-2">Tipo</label>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-2">
            @foreach (var tipo in (SelectList)ViewBag.Tipo)
            {
                <label class="cursor-pointer">
                    <input type="radio" name="Tipo" value="@tipo.Value" @(tipo.Selected ? "checked" : "") class="peer hidden" />
                    <div class="px-3 py-2 text-center text-xs font-medium border border-slate-200 rounded-lg peer-checked:bg-brand-600 peer-checked:text-white peer-checked:border-brand-600 hover:bg-slate-50 transition-colors">
                        @tipo.Text
                    </div>
                </label>
            }
        </div>
        @Html.ValidationMessageFor(m => m.Tipo, "", new { @class = "text-rose-600 text-xs mt-1 block" })
    </div>
</div>
