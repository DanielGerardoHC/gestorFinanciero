@model gestor_financiero.Models.Categoria

@{
    // En vez de pelearnos con Tailwind para que compile clases dinamicas
    // (peer-checked:bg-<color>-600), usamos CSS estandar inline con selectores
    // input:checked + span[data-tipo="X"]. Asi el partial se ve correcto
    // aunque nadie corra "npm run build".
    var tipos = new[]
    {
        new { Value = "INGRESO",        Label = "Ingreso"        },
        new { Value = "AHORRO",         Label = "Ahorro"         },
        new { Value = "GASTO_FIJO",     Label = "Gasto fijo"     },
        new { Value = "GASTO_VARIABLE", Label = "Gasto variable" },
        new { Value = "DEUDA",          Label = "Deuda"          }
    };
    var tipoActivo = !string.IsNullOrWhiteSpace(Model?.Tipo) ? Model.Tipo : "INGRESO";
}

<style>
    .cat-pill { display: block; cursor: pointer; }
    .cat-pill input { position: absolute; opacity: 0; pointer-events: none; width: 0; height: 0; }
    .cat-pill .pill-body {
        display: block;
        padding: 0.5rem 0.75rem;
        text-align: center;
        font-size: 0.75rem;
        font-weight: 500;
        color: #334155;
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        transition: background-color 0.15s, color 0.15s, border-color 0.15s;
    }
    .cat-pill:hover .pill-body { background: #f8fafc; }

    /* Colores por tipo cuando el radio esta checked */
    .cat-pill input:checked + .pill-body[data-tipo="INGRESO"]        { background: #059669; color: white; border-color: #059669; }
    .cat-pill input:checked + .pill-body[data-tipo="AHORRO"]         { background: #0284c7; color: white; border-color: #0284c7; }
    .cat-pill input:checked + .pill-body[data-tipo="GASTO_FIJO"]     { background: #d97706; color: white; border-color: #d97706; }
    .cat-pill input:checked + .pill-body[data-tipo="GASTO_VARIABLE"] { background: #e11d48; color: white; border-color: #e11d48; }
    .cat-pill input:checked + .pill-body[data-tipo="DEUDA"]          { background: #7c3aed; color: white; border-color: #7c3aed; }

    /* Foco visible por accesibilidad */
    .cat-pill input:focus-visible + .pill-body { outline: 2px solid #6366f1; outline-offset: 2px; }
</style>

<div class="space-y-4">
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Nombre</label>
        @Html.TextBoxFor(m => m.Nombre, new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", placeholder = "Ej: Servicios públicos" })
        @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-rose-600 text-xs mt-1 block" })
    </div>
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-2">Tipo de categoría</label>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-2">
            @foreach (var t in tipos)
            {
                var seleccionado = t.Value == tipoActivo;
                <label class="cat-pill">
                    <input type="radio" name="Tipo" value="@t.Value" @(seleccionado ? "checked=\"checked\"" : "") />
                    <span class="pill-body" data-tipo="@t.Value">@t.Label</span>
                </label>
            }
        </div>
        @Html.ValidationMessageFor(m => m.Tipo, "", new { @class = "text-rose-600 text-xs mt-1 block" })
    </div>
</div>
