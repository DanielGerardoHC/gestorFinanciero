@model gestor_financiero.Models.Deuda

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="md:col-span-2">
        <label class="block text-sm font-medium text-slate-700 mb-1">Usuario</label>
        @Html.DropDownList("IdUsuario", (SelectList)ViewBag.IdUsuario, "Seleccione...", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg" })
    </div>
    <div class="md:col-span-2">
        <label class="block text-sm font-medium text-slate-700 mb-1">Nombre de la deuda</label>
        @Html.TextBoxFor(m => m.Nombre, new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", placeholder = "Ej: Tarjeta Visa" })
        @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-rose-600 text-xs mt-1 block" })
    </div>
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Saldo actual</label>
        @Html.TextBoxFor(m => m.SaldoActual, "{0:F2}", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "number", step = "0.01" })
    </div>
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Tasa de interés %</label>
        @Html.TextBoxFor(m => m.TasaInteres, "{0:F2}", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "number", step = "0.01" })
    </div>
    <div class="md:col-span-2">
        <label class="block text-sm font-medium text-slate-700 mb-1">Pago mínimo</label>
        @Html.TextBoxFor(m => m.PagoMinimo, "{0:F2}", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "number", step = "0.01" })
    </div>
    <div class="md:col-span-2">
        <label class="block text-sm font-medium text-slate-700 mb-1">Notas</label>
        @Html.TextAreaFor(m => m.Notas, new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", rows = 2 })
    </div>
</div>
