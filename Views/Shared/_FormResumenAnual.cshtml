@model gestor_financiero.Models.ResumenAnual

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Usuario</label>
        @Html.DropDownList("IdUsuario", (SelectList)ViewBag.IdUsuario, "Seleccione...", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg" })
    </div>
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Año</label>
        @Html.TextBoxFor(m => m.Anio, new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "number", min = 2000, max = 2100 })
    </div>
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Ingresos</label>
        @Html.TextBoxFor(m => m.Ingresos, "{0:F2}", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "number", step = "0.01" })
    </div>
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Ahorros</label>
        @Html.TextBoxFor(m => m.Ahorros, "{0:F2}", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "number", step = "0.01" })
    </div>
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Gastos fijos</label>
        @Html.TextBoxFor(m => m.GastosFijos, "{0:F2}", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "number", step = "0.01" })
    </div>
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Gastos variables</label>
        @Html.TextBoxFor(m => m.GastosVariables, "{0:F2}", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "number", step = "0.01" })
    </div>
    <div class="md:col-span-2">
        <label class="block text-sm font-medium text-slate-700 mb-1">Deudas</label>
        @Html.TextBoxFor(m => m.Deudas, "{0:F2}", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "number", step = "0.01" })
    </div>
</div>
