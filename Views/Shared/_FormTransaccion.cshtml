@model gestor_financiero.Models.Transaccion

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Usuario</label>
        @Html.DropDownList("IdUsuario", (SelectList)ViewBag.IdUsuario, "Seleccione...", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg" })
        @Html.ValidationMessageFor(m => m.IdUsuario, "", new { @class = "text-rose-600 text-xs mt-1 block" })
    </div>
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Categoría</label>
        @Html.DropDownList("IdCategoria", (SelectList)ViewBag.IdCategoria, "Seleccione...", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg" })
        @Html.ValidationMessageFor(m => m.IdCategoria, "", new { @class = "text-rose-600 text-xs mt-1 block" })
    </div>
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Monto</label>
        <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">$</span>
            @Html.TextBoxFor(m => m.Monto, "{0:F2}", new { @class = "w-full pl-7 pr-3 py-2 border border-slate-300 rounded-lg", type = "number", step = "0.01" })
        </div>
        @Html.ValidationMessageFor(m => m.Monto, "", new { @class = "text-rose-600 text-xs mt-1 block" })
    </div>
    <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Fecha</label>
        @Html.TextBoxFor(m => m.Fecha, "{0:yyyy-MM-dd}", new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", type = "date" })
        @Html.ValidationMessageFor(m => m.Fecha, "", new { @class = "text-rose-600 text-xs mt-1 block" })
    </div>
    <div class="md:col-span-2">
        <label class="block text-sm font-medium text-slate-700 mb-1">Notas (opcional)</label>
        @Html.TextAreaFor(m => m.Notas, new { @class = "w-full px-3 py-2 border border-slate-300 rounded-lg", rows = 3, placeholder = "Detalles de la transacción..." })
    </div>
</div>
