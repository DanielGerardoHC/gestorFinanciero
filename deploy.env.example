# Credenciales de produccion (MonsterASP / hosting)
# Copia este archivo a "deploy.env" y completa con tus datos.
# El archivo "deploy.env" esta en .gitignore para no subir credenciales al repo.

# Datos de SQL Server del hosting
# DB_HOST = host INTERNO de MonsterASP (lo usa la app cuando esta deployada).
#          Se ve en la pestania "Local access for websites" del panel.
# DB_HOST_REMOTE = host PUBLICO de MonsterASP (lo usa init-remote-db.ps1 desde tu PC).
#          Se ve en la pestania "Remote access for SSMS" del panel.
DB_HOST=db52546.databaseasp.net,1433
DB_HOST_REMOTE=db52546.public.databaseasp.net,1433
DB_NAME=db52546
DB_USER=db52546
DB_PASSWORD=TuPasswordFuerte!

# Datos de FTP (opcional, para usar con publish.ps1)
FTP_HOST=ftp.monsterasp.net
FTP_USER=tu_usuario_ftp
FTP_PASSWORD=tu_password_ftp
FTP_REMOTE_PATH=/

# URL publica del sitio (para verificacion despues del deploy)
APP_URL=https://gestorfinanciero.monsterasp.net
