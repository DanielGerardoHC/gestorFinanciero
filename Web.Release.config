<?xml version="1.0" encoding="utf-8"?>
<!--
  Transformaciones que se aplican AUTOMATICAMENTE cuando publicas en modo Release.
  El Web.config local sigue intacto (apunta a Docker local).

  IMPORTANTE: Antes de publicar a produccion, edita las cadenas que dicen
  "__PLACEHOLDER__" con tus credenciales reales de MonsterASP / hosting.

  Si no quieres dejar las credenciales en este archivo, podes:
    1. Configurarlas en el panel del hosting (MonsterASP → Site Settings → Connection Strings)
    2. O usar un archivo deploy.env (gitignored) y un script de publish que las inyecta
-->
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">

  <connectionStrings>
    <!-- Reemplaza la cadena local de Docker por la del hosting -->
    <add name="FinanzasContext"
         connectionString="Server=__DB_HOST__;Database=__DB_NAME__;User Id=__DB_USER__;Password=__DB_PASSWORD__;TrustServerCertificate=True;MultipleActiveResultSets=True"
         providerName="System.Data.SqlClient"
         xdt:Transform="SetAttributes" xdt:Locator="Match(name)" />
  </connectionStrings>

  <system.web>
    <!-- Apaga el modo debug para que la app corra mas rapido y seguro -->
    <compilation xdt:Transform="RemoveAttributes(debug)" />

    <!-- TEMPORALMENTE en Off para ver el error real durante el debug.
         Cambiar a "RemoteOnly" antes de pasar a produccion real. -->
    <customErrors mode="Off" xdt:Transform="Insert" />

    <!-- httpOnlyCookies = true: cookies NO accesibles desde JavaScript (anti-XSS)
         requireSSL = false: si fuera true, MonsterASP rompe las cookies porque
         su proxy reverso pasa la request como HTTP a IIS aunque el cliente vea HTTPS,
         entonces el navegador no envia las cookies con flag Secure. -->
    <httpCookies httpOnlyCookies="true" requireSSL="false" xdt:Transform="Insert" />

    <!-- machineKey FIJA para que los tokens antifalsificacion (@Html.AntiForgeryToken)
         sigan funcionando cuando la app se recicla en hosting compartido (MonsterASP).
         Sin esto, cada restart de la app genera keys nuevas y los tokens previos fallan.
         IMPORTANTE: estas claves NO deben filtrarse publicamente.
         Si este archivo se sube a GitHub publico, generar claves nuevas y rotarlas. -->
    <machineKey
        validationKey="c79f5f17b69f283e82ec13d5bce110c4f778ba03cc21c7bd5fd49f877e933774be5e84b97b9e5f3b23801041266a2984d47977fb4a9e997dcacd567ecfdd88c2"
        decryptionKey="934c3524c987ff5f51e72c36440a11198c697d1515a69c8c"
        validation="HMACSHA256"
        decryption="AES"
        xdt:Transform="Insert" />
  </system.web>

  <system.webServer xdt:Transform="InsertIfMissing">
    <!-- Forzar HTTPS y agregar headers de seguridad -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>
    <!-- MIME types para que IIS sirva woff2 correctamente -->
    <staticContent>
      <remove fileExtension=".woff" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>
    <!-- Compresion gzip para CSS/JS -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />
  </system.webServer>

</configuration>
